# Copy to keystore.properties (do NOT commit keystore.properties or .jks files)
storeFile=../core-release.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=core
keyPassword=YOUR_KEY_PASSWORD

# Create keystore once:
#   keytool -genkey -v -keystore core-release.keystore -alias core -keyalg RSA -keysize 2048 -validity 10000
